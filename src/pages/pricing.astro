---
import Layout from "../layouts/Layout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import PartsTag from "../components/PartsTag.astro";
import CtaBand from "../components/CtaBand.astro";
import { getCarbTypes } from "../lib/wix";
import { automotiveBusiness, offerCatalog } from "../lib/jsonld";

const types = await getCarbTypes();
---

<Layout
  title="Pricing by Type"
  description="Flat-rate carburetor rebuild pricing by type — classic car, motorcycle, tractor, marine, and small engine. No surprises before you ship. Prices from $85."
  path="/pricing"
  jsonLd={[automotiveBusiness(), offerCatalog(types)]}
>
  <section class="pegboard text-on-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14 lg:py-20">
      <SectionHeading
        tag="Pricing by type"
        title="Flat prices. No surprises before you ship."
        intro="Each price is the full rebuild for that type — teardown, clean, the right kit, jets verified, and a bench-flow test. I confirm the exact number for your carb before you send it."
        onDark
      />
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <ul class="grid gap-px bg-border border border-border md:grid-cols-2">
      {
        types.map((c) => (
          <li class="bg-surface flex flex-col">
            <div class="grid grid-cols-[1fr_auto] gap-4 p-6 border-b border-border">
              <div>
                <p class="label-caps">{c.vehicleKind}</p>
                <h2 class="mt-1 font-display text-2xl text-primary leading-tight">
                  {c.typeName}
                </h2>
              </div>
              <div class="text-right">
                <p class="font-display text-3xl text-accent leading-none">
                  ${c.priceFlat}
                </p>
                <p class="label-caps mt-2">{c.turnaroundDays}</p>
              </div>
            </div>
            <div class="p-6 flex-1">
              <p class="label-caps mb-2">What's included</p>
              <p class="text-text-muted leading-relaxed">{c.whatsIncluded}</p>
              <p class="label-caps mt-5 mb-1">Common models</p>
              <p class="text-text">{c.commonModels}</p>
            </div>
            <div class="p-6 pt-0">
              <a href="/service-request" class="btn btn-ghost w-full">
                Start a request for this type
              </a>
            </div>
          </li>
        ))
      }
    </ul>

    <div class="mt-10 bin p-7">
      <PartsTag label="No payment up front" />
      <p class="mt-3 text-text-muted max-w-2xl leading-relaxed">
        You send the request, I confirm I can do the job and quote the flat
        price for your type, then you ship. Payment comes after the rebuild,
        before it goes back in the mail. If a casting's cracked or a bore is
        worn past spec, I'll call before doing more work — and I won't charge
        you for a rebuild that won't hold.
      </p>
    </div>
  </section>

  <CtaBand />
</Layout>
