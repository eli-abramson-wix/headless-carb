---
import Layout from "../layouts/Layout.astro";
import PartsTag from "../components/PartsTag.astro";
import CtaBand from "../components/CtaBand.astro";
import { getCarbTypes } from "../lib/wix";
import { automotiveBusiness, offerCatalog } from "../lib/jsonld";

const types = await getCarbTypes();

// The rebuild, in three stamped steps — shop voice, mirrors what's in
// every "what's included" line above.
const process = [
  [
    "01",
    "Ultrasonic clean",
    "Every passage and bowl run through the ultrasonic tank — no shortcuts, no leftover varnish.",
  ],
  [
    "02",
    "Jets verified to spec",
    "New gaskets, needle-and-seat, and o-rings, then every jet checked against the book — not just cleaned and hoped for.",
  ],
  [
    "03",
    "Bench-flow tested",
    "It runs on the flow bench before it boxes up, and the numbers go in the box with the part.",
  ],
];
---

<Layout
  title="Pricing by Type"
  description="Flat-rate carburetor rebuild pricing by type — classic car, motorcycle, tractor, marine, and small engine. No surprises before you ship. Prices from $85."
  path="/pricing"
  jsonLd={[automotiveBusiness(), offerCatalog(types)]}
>
  <!-- ── Hero ───────────────────────────────────────────── -->
  <section class="pegboard text-on-dark">
    <div
      class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14 lg:py-20 grid lg:grid-cols-[1.3fr_1fr] gap-10 lg:gap-14 items-center"
    >
      <div>
        <PartsTag label="Pricing by type" class="!bg-surface" />
        <h1
          class="mt-5 font-display text-4xl sm:text-5xl headline-stamped leading-[1.02]"
        >
          Flat prices. No surprises before you ship.
        </h1>
        <p class="mt-4 text-lg text-on-dark/75 max-w-xl leading-relaxed">
          Each price is the full rebuild for that type — teardown, clean, the
          right kit, jets verified, and a bench-flow test. I confirm the exact
          number for your carb before you send it.
        </p>
      </div>
      <div class="border border-on-dark/20">
        <img
          src="/images/monojet.jpg"
          alt="A Rochester Monojet carburetor mid-teardown on a workshop bench"
          width="1200"
          height="900"
          loading="eager"
          class="w-full aspect-[4/3] object-cover"
        />
      </div>
    </div>
  </section>

  <!-- ── Rate schedule (the manifest table) ─────────────── -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <h2 class="font-display text-2xl sm:text-3xl text-primary">
      Rate schedule by unit type
    </h2>
    <div class="mt-2 h-0.5 w-44 bg-accent"></div>

    <div class="mt-8 border-t border-border">
      <!-- Column headers (desktop) -->
      <div
        class="hidden md:grid grid-cols-[3rem_1fr_12rem_10rem] gap-4 py-3 border-b border-border label-caps"
      >
        <span>Ref#</span>
        <span>Carburetor configuration</span>
        <span>Est. turnaround</span>
        <span class="text-right">Service flat rate</span>
      </div>

      {
        types.map((c, i) => (
          <div class="grid gap-4 py-6 border-b border-border md:grid-cols-[3rem_1fr_12rem_10rem] md:items-center">
            <span class="manifest-num text-base">
              {String(i + 1).padStart(2, "0")}
            </span>
            <div>
              <p class="label-caps md:hidden">{c.vehicleKind}</p>
              <h3 class="font-display text-xl text-primary leading-tight">
                {c.typeName}
              </h3>
              <p class="mt-1 text-sm text-text-muted">{c.commonModels}</p>
            </div>
            <div>
              <span class="inline-flex items-center gap-1.5 border border-border bg-surface px-2.5 py-1 label-caps !text-text">
                <svg
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="9" />
                  <polyline points="12 7 12 12 16 14" />
                </svg>
                {c.turnaroundDays}
              </span>
            </div>
            <div class="md:text-right md:justify-self-end">
              <span class="relative inline-flex items-center border border-border bg-surface pl-6 pr-4 py-2">
                <span class="absolute left-2 top-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-background ring-1 ring-border" />
                <span class="font-display text-2xl text-accent leading-none">
                  ${c.priceFlat}
                </span>
              </span>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-10 bin p-7">
      <PartsTag label="No payment up front" />
      <p class="mt-3 text-text-muted max-w-2xl leading-relaxed">
        You send the request, I confirm I can do the job and quote the flat
        price for your type, then you ship. Payment comes after the rebuild,
        before it goes back in the mail. If a casting's cracked or a bore is
        worn past spec, I'll call before doing more work — and I won't charge
        you for a rebuild that won't hold.
      </p>
    </div>
  </section>

  <!-- ── What the flat rate covers ──────────────────────── -->
  <section class="pegboard text-on-dark">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
      <p class="label-caps !text-on-dark/60">What the flat rate covers</p>
      <h2 class="mt-2 font-display text-2xl sm:text-3xl text-on-dark">
        Every rebuild, the same three steps
      </h2>
      <div
        class="mt-8 grid gap-px bg-on-dark/15 border border-on-dark/15 md:grid-cols-3"
      >
        {
          process.map(([n, t, d]) => (
            <div class="pegboard p-6 md:p-8">
              <span class="manifest-num text-2xl">{n}</span>
              <p class="mt-3 font-display text-lg text-on-dark">{t}</p>
              <p class="mt-2 text-on-dark/70 leading-relaxed">{d}</p>
            </div>
          ))
        }
      </div>
      <div class="mt-8">
        <a href="/service-request" class="btn btn-accent"
          >Start your service request</a
        >
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>
