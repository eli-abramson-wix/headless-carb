---
import Layout from "../layouts/Layout.astro";
import PartsTag from "../components/PartsTag.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CtaBand from "../components/CtaBand.astro";
import YouTubeFacade from "../components/YouTubeFacade.astro";
import { getCarbTypes, getReviews, getBenchQueue } from "../lib/wix";
import { automotiveBusiness } from "../lib/jsonld";

const carbTypes = await getCarbTypes();
const reviews = await getReviews();
const bench = await getBenchQueue();
const pricePreview = carbTypes.slice(0, 4);
const onBench = bench.find((b) => b.state === "On the bench") ?? bench[0];

const steps = [
  { n: "01", t: "Box it up", d: "Drain the fuel, let it dry, wrap it snug so it can't rattle." },
  { n: "02", t: "Fill out the form", d: "Tell me the engine, the carb, and what it's doing wrong." },
  { n: "03", t: "Ship it", d: "I email you the address and how to pack it. Then it's on its way." },
  { n: "04", t: "Get it back rebuilt", d: "Cleaned, rebuilt, bench-flow tested, with the numbers in the box." },
];
---

<Layout
  title="Mail-in carburetor rebuild"
  description="Mail me the carburetor, I'll mail it back working. A one-man rural-Ohio shop rebuilding every type of carburetor by mail — flat pricing, honest diagnosis, bench-flow tested."
  path="/"
  jsonLd={[automotiveBusiness()]}
>
  <!-- ── Hero ───────────────────────────────────────────── -->
  <section class="pegboard text-on-dark">
    <div
      class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-20 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center"
    >
      <div class="order-2 lg:order-1">
        <span class="stamp-in inline-block parts-tag">Rural Ohio · Est. 2003</span>
        <h1
          class="stamp-in stamp-in-1 mt-5 font-display text-4xl sm:text-5xl lg:text-6xl leading-[0.98] text-on-dark"
        >
          Mail me the carburetor. I'll mail it back working.
        </h1>
        <p
          class="stamp-in stamp-in-2 mt-5 text-lg sm:text-xl text-on-dark/75 max-w-xl leading-relaxed"
        >
          One bench, one guy, and a wall of jets sorted A to Z. If it mixes
          fuel and air, I've probably had one apart.
        </p>
        <div class="stamp-in stamp-in-3 mt-8 flex flex-col sm:flex-row sm:flex-wrap gap-3">
          <a href="/service-request" class="btn btn-accent">Start a service request</a>
          <a
            href="https://youtube.com/@thecarburetorwhisperer"
            target="_blank"
            rel="noopener"
            class="btn btn-on-dark">Watch a teardown</a
          >
        </div>
      </div>

      <div class="order-1 lg:order-2 stamp-in">
        <div class="relative border border-on-dark/20">
          <img
            src="/images/hero.jpg"
            alt="Grease-stained hands holding a freshly rebuilt brass carburetor over a workshop bench"
            width="1600"
            height="900"
            fetchpriority="high"
            class="w-full aspect-square lg:aspect-[4/3] object-cover"
          />
          <span
            class="absolute left-3 bottom-3 parts-tag !bg-surface/95"
            >Bench-flow tested</span
          >
        </div>
      </div>
    </div>
  </section>

  <!-- ── What I Do ──────────────────────────────────────── -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-10 items-center">
      <div>
        <SectionHeading
          tag="What I do"
          title="One bench. One guy. A wall of jets, A to Z."
          intro="There's no front desk and no franchise behind me. You're sending your part to the same person who tears it down, cleans it, rebuilds it, and flow-tests it before it goes back in the box."
        />
        <ul class="mt-7 grid sm:grid-cols-2 gap-px bg-border border border-border">
          {
            [
              ["Every type, by mail", "Cars, motorcycles, tractors, outboards, small engines."],
              ["Flat pricing", "You know the number before the box leaves your porch."],
              ["Honest diagnosis", "If it can't be saved, I tell you straight — before any work."],
              ["Bench-flow tested", "It doesn't ship back until it actually runs right."],
            ].map(([t, d]) => (
              <li class="bg-surface p-5">
                <p class="font-display text-lg text-primary">{t}</p>
                <p class="mt-1 text-text-muted">{d}</p>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="border border-border">
        <img
          src="/images/jet-wall.jpg"
          alt="A workshop wall of brass jets and small-engine parts, meticulously alphabetized in drawers"
          width="1200"
          height="900"
          loading="lazy"
          class="w-full h-full object-cover aspect-[4/3]"
        />
      </div>
    </div>
  </section>

  <!-- ── How it works ───────────────────────────────────── -->
  <section class="border-y border-border bg-surface">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
      <SectionHeading
        tag="How mail-in works"
        title="Box it up. Ship it. Get it back rebuilt."
        intro="No appointment, no drop-off, no waiting room."
      />
      <ol class="mt-8 grid gap-px bg-border border border-border sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((s) => (
            <li class="bg-background p-6">
              <span class="manifest-num text-2xl">{s.n}</span>
              <p class="mt-2 font-display text-xl text-primary">{s.t}</p>
              <p class="mt-2 text-text-muted leading-relaxed">{s.d}</p>
            </li>
          ))
        }
      </ol>
      <div class="mt-8">
        <a href="/how-it-works" class="btn btn-ghost">See the full process</a>
      </div>
    </div>
  </section>

  <!-- ── On the bench right now ──────────────────────────── -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_1.2fr] gap-10 items-start">
      <SectionHeading
        tag="On the bench right now"
        title="Here's what's clamped in the vise this week"
        intro="A live look at the line so you know roughly where your carb would land if you shipped it today."
      />
      <div class="bin">
        <div class="flex items-center gap-3 p-5 border-b border-border">
          <span class="relative flex h-2.5 w-2.5">
            <span class="absolute inline-flex h-full w-full rounded-full bg-accent opacity-75 motion-safe:animate-ping"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-accent"></span>
          </span>
          <p class="label-caps !text-text">Now: {onBench.carb} — {onBench.owner}</p>
        </div>
        <p class="px-5 py-4 text-text-muted">{onBench.note}</p>
        <div class="px-5 pb-5">
          <a href="/on-the-bench" class="btn btn-ghost">See the full line</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Pricing preview ────────────────────────────────── -->
  <section class="border-y border-border bg-surface">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
      <SectionHeading
        tag="Pricing preview"
        title="Flat prices by type"
        intro="You'll know the number before the box leaves your porch. Full list on the pricing page."
      />
      <ul class="mt-8 grid gap-px bg-border border border-border sm:grid-cols-2 lg:grid-cols-4">
        {
          pricePreview.map((c) => (
            <li class="bg-background p-5 flex flex-col">
              <p class="label-caps">{c.vehicleKind}</p>
              <p class="mt-1 font-display text-lg text-primary leading-tight">
                {c.typeName}
              </p>
              <p class="mt-auto pt-4 flex items-baseline gap-2">
                <span class="font-display text-3xl text-accent">${c.priceFlat}</span>
                <span class="text-sm text-text-muted">/ {c.turnaroundDays}</span>
              </p>
            </li>
          ))
        }
      </ul>
      <div class="mt-8">
        <a href="/pricing" class="btn btn-primary">See all pricing</a>
      </div>
    </div>
  </section>

  <!-- ── Reviews ────────────────────────────────────────── -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <SectionHeading
      tag="From people who shipped one in"
      title="Folks who trusted the mail"
    />
    <ul class="mt-8 grid gap-px bg-border border border-border md:grid-cols-3">
      {
        reviews.map((r) => (
          <li class="bg-surface p-6 flex flex-col">
            <p class="text-lg leading-relaxed text-text">“{r.quote}”</p>
            <div class="mt-5 pt-4 border-t border-border">
              <p class="font-display text-primary">{r.name}</p>
              <p class="label-caps mt-1">{r.detail}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- ── The channel ────────────────────────────────────── -->
  <section class="border-t border-border bg-surface">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 grid lg:grid-cols-2 gap-10 items-center">
      <div>
        <SectionHeading
          tag="The channel"
          title="The teardowns pay the heating bill"
          intro="They also show you exactly how your carb gets fixed — every jet, every gasket, the bench-flow numbers at the end."
        />
        <a
          href="https://youtube.com/@thecarburetorwhisperer"
          target="_blank"
          rel="noopener"
          class="btn btn-ghost mt-6">Visit the channel</a
        >
      </div>
      <YouTubeFacade
        videoId="ScMzIvxBSi4"
        poster="/images/monojet.jpg"
        title="Rochester Monojet — full teardown"
      />
    </div>
  </section>

  <CtaBand
    heading="Ready to send it in?"
    body="Start the request and I'll mail you where to ship. Don't ship it until you hear from me."
  />
</Layout>
